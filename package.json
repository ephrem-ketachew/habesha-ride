{
  "name": "kech-backend-v2",
  "version": "1.0.0",
  "description": "Backend API for Kech.ai v2.0 MVP",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "kech",
    "marketplace",
    "api",
    "express",
    "mongodb",
    "typescript"
